{
    "compilerOptions": {
      "target": "es2022",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
"noEmitOnError": true,
      "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"],
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules"
    ]
  }
  